# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# ── Notifications (ntfy.sh) ───────────────────────────────────────────────
# Pick a hard-to-guess topic, then subscribe to it in the ntfy mobile app.
# Leave NTFY_TOPIC empty to run in DRY-RUN mode (alerts print to the console).
NTFY_SERVER=https://ntfy.sh
NTFY_TOPIC=

# ── Reddit OAuth (recommended — anonymous .json is throttled/403'd) ───────
# 1. Create an app at https://www.reddit.com/prefs/apps
#       type: web app   |   redirect uri: http://localhost:8080
# 2. Fill in the id/secret below, then run:  python -m tcgmon.reddit_auth
# 3. Paste the REDDIT_REFRESH_TOKEN it prints back here.
# With all three set, the reddit_json fetcher uses the authenticated API.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_REFRESH_TOKEN=

# ── Best Buy Products API (free key: https://developer.bestbuy.com) ───────
BESTBUY_API_KEY=

# ── Misc ──────────────────────────────────────────────────────────────────
# SQLite state file location.
TCGMON_DB=state.db
# Interval jitter spread (0.3 = ±30%).
TCGMON_JITTER=0.3
