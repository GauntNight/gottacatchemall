# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# ── Notifications (ntfy.sh) ───────────────────────────────────────────────
# Pick a hard-to-guess topic, then subscribe to it in the ntfy mobile app.
# Leave NTFY_TOPIC empty to run in DRY-RUN mode (alerts print to the console).
NTFY_SERVER=https://ntfy.sh
NTFY_TOPIC=

# ── Reddit access — pick ONE path (anonymous .json is throttled/403'd) ────
#
# Path A (default in targets.yaml): logged-in browser session, no app needed.
#   pip install -e ".[browser]" && playwright install chromium
#   python -m tcgmon.reddit_login        # log in once; saves the session
#   Optionally relocate the saved session file:
# REDDIT_SESSION_FILE=.reddit_session.json
#
# Path B: OAuth app (no browser at runtime; needs app creation).
#   Create a "web app" at https://www.reddit.com/prefs/apps (redirect
#   uri http://localhost:8080), fill these in, run python -m tcgmon.reddit_auth,
#   paste back the refresh token, and set fetcher: reddit_json in targets.yaml.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_REFRESH_TOKEN=

# ── Best Buy Products API (free key: https://developer.bestbuy.com) ───────
BESTBUY_API_KEY=

# ── Misc ──────────────────────────────────────────────────────────────────
# SQLite state file location.
TCGMON_DB=state.db
# Interval jitter spread (0.3 = ±30%).
TCGMON_JITTER=0.3
