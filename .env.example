# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# ── Notifications (ntfy.sh) ───────────────────────────────────────────────
# Pick a hard-to-guess topic, then subscribe to it in the ntfy mobile app.
# Leave NTFY_TOPIC empty to run in DRY-RUN mode (alerts print to the console).
NTFY_SERVER=https://ntfy.sh
NTFY_TOPIC=

# ── Best Buy Products API (free key: https://developer.bestbuy.com) ───────
BESTBUY_API_KEY=

# ── Misc ──────────────────────────────────────────────────────────────────
# SQLite state file location.
TCGMON_DB=state.db
# Interval jitter spread (0.3 = ±30%).
TCGMON_JITTER=0.3
